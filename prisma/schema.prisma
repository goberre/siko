generator client {
  provider = "prisma-client-js"
  runtime  = "cloudflare"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth 필수 모델 ───────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── 유저 ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String
  role          String    @default("user")     // "user" | "admin"
  image         String?
  phone         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 사업자 인증
  businessNumber       String?                   // 000-00-00000 형식
  businessName         String?                   // 상호명
  businessVerified     Boolean   @default(false) // 국세청 API 인증 여부
  businessStatus       String?                   // "계속사업자" | "휴업자" | "폐업자"
  businessLastCheckedAt DateTime?               // 마지막 재검증 일시
  businessActive       Boolean   @default(true) // 폐업·휴업 감지 시 false

  // 계정 보안 (잠금)
  loginAttempts Int      @default(0)
  lockedUntil   DateTime?

  accounts  Account[]
  sessions  Session[]
  orders    Order[]
  auditLogs AuditLog[]
}

// ─── 감사 로그 ────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // LOGIN_SUCCESS | LOGIN_FAIL | REGISTER | LOCKOUT | PASSWORD_RESET | ADMIN_ACTION
  ip        String?
  userAgent String?
  detail    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ─── 서비스 ──────────────────────────────────────────────

model Service {
  id          String   @id @default(cuid())
  title       String
  category    String
  subcategory String   @default("")
  industry    String[] // 업종 ID 배열
  price       Int
  priceUnit   String   @default("건")
  rating      Float    @default(5.0)
  reviewCount Int      @default(0)
  badge       String?  // "인기" | "신규" | "추천"
  description String   @default("")
  tags        String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── 주문 ────────────────────────────────────────────────

model Order {
  id          String   @id @default(cuid())
  userId      String
  serviceId   String
  serviceName String
  tier        String
  amount      Int
  status      String   @default("pending")  // pending | processing | completed | cancelled

  // 작업 요청사항
  requestUrl     String?  // 작업 대상 URL (플레이스, 스토어, 유튜브 등)
  requestKeyword String?  // 목표 키워드
  requestMemo    String?  // 추가 요청사항

  // 관리자 메모 (진행 상황 기록)
  adminMemo   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
