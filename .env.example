# ─── Database (Neon PostgreSQL) ──────────────────────────
# https://neon.tech 에서 무료 계정 생성 후 연결 문자열 복사
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────
# 생성 방법: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
AUTH_SECRET="your-secret-here"
NEXTAUTH_SECRET="your-secret-here"   # AUTH_SECRET 과 동일하게 설정
NEXTAUTH_URL="https://your-domain.pages.dev"

# ─── 국세청 사업자등록 상태조회 API ─────────────────────
# https://www.data.go.kr 에서 '국세청_사업자등록정보' 서비스 신청
NTS_SERVICE_KEY="your-nts-key-here"

# ─── 크론 보안 키 ────────────────────────────────────────
# 생성 방법: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-cron-secret-here"
